# ADAN-ID OpenCloud Environment Configuration
# Source: ADAN-ID Sovereign Cloud Architect Agent (Google Doc)
# Deployed: 2026-04-23 by Adnan Bhai (Muhammad Adnan Ul Mustafa)
# Copy this file to .env and fill in your values

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-with-abjad-entropy
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# ============================================
# FIREBASE CONFIGURATION
# ============================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# ============================================
# GITHUB CONFIGURATION
# ============================================
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_ORG=ADANiD-AI
GITHUB_REPO=adan-id-opencloud

# ============================================
# MONGODB ATLAS
# ============================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/adan-id-cloud
MONGODB_DB_NAME=adan-id-cloud

# ============================================
# CLOUDFLARE R2 STORAGE
# ============================================
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=adan-id-storage
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ============================================
# IPFS CONFIGURATION
# ============================================
IPFS_GATEWAY=https://ipfs.io/ipfs/
IPFS_API_URL=https://api.pinata.cloud
IPFS_API_KEY=your-pinata-api-key
IPFS_SECRET_KEY=your-pinata-secret-key

# ============================================
# ENCRYPTION (AES-256-GCM)
# ============================================
ENCRYPTION_KEY=your-32-byte-aes-256-encryption-key
ENCRYPTION_IV_LENGTH=16
ABJAD_ENTROPY_SEED=bismillah-ar-rahman-ar-raheem

# ============================================
# SERVICE PORTS
# ============================================
API_GATEWAY_PORT=3000
WEBSOCKET_PORT=3001
AUTH_SERVICE_PORT=4000
STORAGE_SERVICE_PORT=5000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ============================================
# MONITORING
# ============================================
GRAFANA_ADMIN_PASSWORD=your-grafana-admin-password
PROMETHEUS_RETENTION=15d
LOKI_RETENTION=30d

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# BIOMETRIC AUTH
# ============================================
BIOMETRIC_MATCH_THRESHOLD=0.85
BIOMETRIC_MAX_ATTEMPTS=3
DID_METHOD=did:adan

# ============================================
# GENERAL
# ============================================
NODE_ENV=production
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=30000
CORS_ORIGIN=https://adan-id.com